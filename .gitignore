# Virtual environments
.venv/
venv/
env/

# Development docs and tooling.
# docs/ is ignored EXCEPT the docs that feed the compiled wiki (.claude/wiki/):
# those MUST stay tracked so wiki-build's git-log staleness detection notices
# their changes. Use docs/* (not docs/) so the negations below can re-include
# subpaths — git cannot re-include a path whose parent dir is excluded outright.
docs/*
!docs/TECH_STACK.md
!docs/TRAINING_GUIDE.md
!docs/auto-editor-plan/
.claude/

# Build system generated files
config.mk
build/
dist/

# PyInstaller
*.spec
!pickleball-editor.spec

# Python
*.pyc
*.pyo
__pycache__/
*.egg-info/
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Linting/Type checking
.mypy_cache/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Claude Code
.claude/settings.json
.claude/settings.local.json
.claude/statusline.sh

# Debug/temporary files
DEBUG_LOCALE.txt
*.log

# Large video files
*.mp4
*.mkv
*.avi
*.mov

# Kdenlive cache and proxy files
proxy/
**/proxy/

# ML pipeline training cache and model checkpoints (large binaries)
ml/cache/
ml/checkpoints/
*.pt
*.npy
